# Copiá este archivo como application-local.properties y completá tus valores locales.
# Este archivo NO debe subirse al repositorio.

DB_URL=jdbc:postgresql://localhost:5433/tutorias_db
DB_USERNAME=tu_usuario
DB_PASSWORD=tu_password

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo
MAIL_PASSWORD=tu_clave_de_aplicacion
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

JWT_SECRET=una-clave-larga-de-al-menos-32-caracteres

# Opcional
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
